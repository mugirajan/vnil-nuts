# Copy this file to .env in the same directory (php/.env) and fill in real values.
# DO NOT commit .env — it's listed in .gitignore.

# Gmail SMTP credentials
# IMPORTANT: use a Google App Password, NOT your regular account password.
# Generate one at https://myaccount.google.com/apppasswords (requires 2FA enabled).
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-16-char-app-password

# Google reCAPTCHA v2 (Checkbox) secret key
# Get from https://www.google.com/recaptcha/admin
# Site key lives in HTML (contact-us.html); SECRET key lives only here.
RECAPTCHA_SECRET=your-recaptcha-secret-here
